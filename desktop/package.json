{
  "name": "OrcaPlay",
  "version": "0.1.0",
  "engines": {
    "node": ">= 20"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron . --disable-gpu",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "de.karstenj.orca-play",
    "productName": "OrcaPlay",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "icon.*"
    ],
    "extraResources": [
      { "from": "../Orca", "to": "Orca" },
      { "from": "../Pilot", "to": "Pilot" },
      { "from": "../scripts", "to": "scripts" },
      { "from": "../links", "to": "links" },
      { "from": "../media", "to": "media" }
    ],
    "win": { "icon": "icon.ico" },
    "mac": { "icon": "icon.icns" },
    "linux": { "icon": "icon.png" }
  },
  "standard": {
    "globals": [
      "localStorage",
      "DOMParser",
      "performance",
      "Worker"
    ],
    "ignore": [
      "/node_modules/*"
    ]
  }
}
